# ============================================================
# Ecvaultz — .gitignore
# ============================================================

# --- Dependencies ---
/vendor
/node_modules

# --- Build artifacts ---
/public/build
/public/storage
/public/hot

# --- Environment files (CRITICAL: NEVER commit these) ---
.env
.env.backup
.env.local
.env.production
.env.staging
.env.*.local

# --- SQLite databases ---
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# --- Storage (encrypted user data — NEVER commit) ---
/storage/*.key
/storage/logs/*.log
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/app/private/*
/storage/app/public/*
!storage/app/private/.gitkeep
!storage/app/public/.gitkeep
/storage/debugbar/

# --- Cache & temp ---
.phpunit.result.cache
.php-cs-fixer.cache
/.phpunit.cache
/tests/coverage
/bootstrap/cache/*.php
!bootstrap/cache/.gitkeep

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*.bak
~*

# --- IDE & Editors ---
.idea
.vscode
*.sublime-*
*.code-workspace
.project
.settings/
*.sublime-project

# --- Docker ---
docker-compose.override.yml

# --- Project analysis (local only, large files) ---
*.txt.backup
docker-entrypoint.sh
nginx.conf

# --- Backup & temp files ---
*.backup
*.old
*.orig
*.patch

# --- Environment & secrets ---
.env.*
!.env.example
*.pem
*.key
*.crt
credentials.json

# --- Debug & profiling ---
/xdebug-profile/
/telescope-records/
/clockwork/
