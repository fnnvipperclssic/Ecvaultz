{
  "name": "Ecvaultz - Digital Vault",
  "short_name": "Ecvaultz",
  "description": "Secure digital vault with AES-256-GCM encryption and two-factor authentication",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#060a12",
  "theme_color": "#7c22ff",
  "orientation": "any",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["productivity", "security", "utilities"],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Upload File",
      "url": "/files",
      "description": "Upload files to your vault"
    },
    {
      "name": "My Shares",
      "url": "/shares",
      "description": "View your shared files"
    }
  ],
  "share_target": {
    "action": "/files",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "files",
          "accept": ["*/*"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/files",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg", ".webp"],
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": [".docx"],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"]
      }
    }
  ]
}
