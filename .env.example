# =============================================================================
# Ecvaultz — Brangkas Digital (Digital Vault)
# Environment Configuration Template
# =============================================================================
# Copy file ini ke .env dan sesuaikan nilainya dengan environment Anda.
# JANGAN commit .env ke version control!
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Ecvaultz
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
# Generate via: php artisan key:generate
APP_KEY=

# Force HTTPS scheme di production (set true jika di belakang HTTPS proxy)
FORCE_HTTPS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database: MariaDB (recommended) atau MySQL
# ---------------------------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecvaultz
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Redis (optional untuk dev, recommended untuk production)
# ---------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ecvaultz_

# ---------------------------------------------------------------------------
# Mail: log untuk dev, smtp untuk production
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ecvaultz.test"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Session: database recommended, redis untuk scale
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=null

# ---------------------------------------------------------------------------
# Cache & Queue
# ---------------------------------------------------------------------------
CACHE_DRIVER=file
FILESYSTEM_DISK=private
QUEUE_CONNECTION=sync

# ---------------------------------------------------------------------------
# File Upload Security
# ---------------------------------------------------------------------------
# Enable ClamAV virus scanning (requires clamav-daemon running)
SCAN_UPLOADS=false
CLAMAV_SOCKET=unix:///var/run/clamav/clamd.ctl
# Maximum upload size dalam bytes (default 50MB)
MAX_UPLOAD_SIZE=52428800
# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,docx,xlsx,jpg,png,7z
# Default storage quota per user dalam bytes (default 5GB)
DEFAULT_STORAGE_QUOTA=5368709120

# ---------------------------------------------------------------------------
# Rate Limiting (per menit)
# ---------------------------------------------------------------------------
UPLOAD_RATE_LIMIT=10
DOWNLOAD_RATE_LIMIT=20
RESET_REQUEST_LIMIT=3

# ---------------------------------------------------------------------------
# Two-Factor Authentication (TOTP)
# ---------------------------------------------------------------------------
TWO_FACTOR_REQUIRED=false
TWO_FACTOR_ISSUER=Ecvaultz
RECOVERY_CODES_COUNT=8

# ---------------------------------------------------------------------------
# Password Policy (OWASP A07)
# ---------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMERIC=true
PASSWORD_REQUIRE_SYMBOL=true
PASSWORD_EXPIRY_DAYS=90

# ---------------------------------------------------------------------------
# Account Lockout (OWASP A07)
# ---------------------------------------------------------------------------
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15

# ---------------------------------------------------------------------------
# Data Retention
# ---------------------------------------------------------------------------
SOFT_DELETE_RETENTION_DAYS=30
MAX_BULK_DELETE=100
CONFIRMATION_BULK_DELETE_THRESHOLD=10

# ---------------------------------------------------------------------------
# Cache TTL (dalam detik)
# ---------------------------------------------------------------------------
CACHE_TTL_FILES=300

# ---------------------------------------------------------------------------
# Session Idle Timeout (dalam detik, default 30 menit)
# ---------------------------------------------------------------------------
SESSION_IDLE_TIMEOUT=1800

# ---------------------------------------------------------------------------
# HSTS: 0 di dev, 31536000 di production (1 tahun)
# ---------------------------------------------------------------------------
HSTS_MAX_AGE=0
HSTS_INCLUDE_SUBDOMAINS=true

# ---------------------------------------------------------------------------
# Trusted Proxies: null di dev, "*" di belakang load balancer
# ---------------------------------------------------------------------------
TRUSTED_PROXIES=null
