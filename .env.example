APP_NAME=Ecvaultz
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database: MariaDB (recommended)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecvaultz
DB_USERNAME=root
DB_PASSWORD=

# Redis (optional for dev, recommended for production)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ecvaultz_

# Mail: log for dev, smtp for production
# Free options: Mailtrap (1000/mo), Resend (100/day), Mailpit (self-hosted)
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@ecvaultz.test"
MAIL_FROM_NAME="${APP_NAME}"

# Session: database recommended, redis for scale
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_DOMAIN=null

CACHE_DRIVER=file
FILESYSTEM_DISK=private
QUEUE_CONNECTION=sync

# File upload security
SCAN_UPLOADS=false
CLAMAV_SOCKET=unix:///var/run/clamav/clamd.ctl
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,xlsx,jpg,png,7z

# Rate limiting
UPLOAD_RATE_LIMIT=10
DOWNLOAD_RATE_LIMIT=20
RESET_REQUEST_LIMIT=3

# Two-Factor Authentication
TWO_FACTOR_REQUIRED=false
TWO_FACTOR_ISSUER=Ecvaultz
RECOVERY_CODES_COUNT=8

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMERIC=true
PASSWORD_REQUIRE_SYMBOL=true
PASSWORD_EXPIRY_DAYS=90

# Account lockout
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15

# Data retention
SOFT_DELETE_RETENTION_DAYS=30
MAX_BULK_DELETE=100
CONFIRMATION_BULK_DELETE_THRESHOLD=10

# Cache
CACHE_TTL_FILES=300

# Session idle timeout (seconds)
SESSION_IDLE_TIMEOUT=1800

# HSTS (set to 31536000 in production, 0 in dev)
HSTS_MAX_AGE=0
HSTS_INCLUDE_SUBDOMAINS=true

# Trusted proxies (set to * behind load balancer, null otherwise)
TRUSTED_PROXIES=null
